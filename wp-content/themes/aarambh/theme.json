{
	"$schema": "https://schemas.wp.org/wp/7.0/theme.json",
	"version": 3,
	"customTemplates": [
		{
			"name": "frontpage",
			"postTypes": [
				"page"
			],
			"title": "Front Page"
		}
	],
	"settings": {
		"appearanceTools": true,
		"color": {
			"custom": true,
			"customDuotone": false,
			"customGradient": false,
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"gradients": [
				{
                "name": "background-gradient",
                "slug": "background-gradient",
                "gradient": "linear-gradient(56deg, #000000 0%, #302A07 100%)"
				}
			],
			"palette": [
				{
					"color": "#00000000",
					"name": "Background",
					"slug": "background"
				},
				{
					"color": "#1F1F12",
					"name": "Surface",
					"slug": "surface"
				},
				{
					"color": "#eff0bd",
					"name": "Foreground",
					"slug": "foreground"
				},
				{
					"color": "#d2ca28",
					"name": "Heading Muted",
					"slug": "heading-muted"
				},
				{
					"color": "#d9dce7",
					"name": "Muted",
					"slug": "muted"
				},
				{
					"color": "#a7a932",
					"name": "Accent",
					"slug": "accent"
				},
				{
					"color": "#e6f1ff",
					"name": "White",
					"slug": "white"
				}
			]
		},
		"layout": {
			"contentSize": "1200px",
			"wideSize": "1400px"
		},
		"shadow": {
			"presets": [
				{
					"name": "Card Shadow",
					"shadow": "6px 6px 0px 0px #a7a932",
					"slug": "card"
				}
			]
		},
		"spacing": {
			"spacingSizes": [
				{
					"name": "1",
					"size": "1rem",
					"slug": "20"
				},
				{
					"name": "2",
					"size": "1.5rem",
					"slug": "30"
				},
				{
					"name": "3",
					"size": "2rem",
					"slug": "40"
				},
				{
					"name": "4",
					"size": "2.5rem",
					"slug": "50"
				},
				{
					"name": "5",
					"size": "3rem",
					"slug": "60"
				},
				{
					"name": "6",
					"size": "4rem",
					"slug": "70"
				},
				{
					"name": "7",
					"size": "5rem",
					"slug": "80"
				},
				{
					"name": "Section",
					"size": "clamp(5rem, 10vw, 8rem)",
					"slug": "90"
				}
			],
			"units": [
				"%",
				"px",
				"em",
				"rem",
				"vh",
				"vw"
			]
		},
		"typography": {
			"customFontSize": true,
			"fontFamilies": [
				{
					"fontFamily": "\"SF Mono\", \"Fira Code\", \"Fira Mono\", \"Roboto Mono\", monospace",
					"name": "Mono",
					"slug": "mono"
				},
				{
					"fontFamily": "\"Calibre\", \"Inter\", \"San Francisco\", \"SF Pro Text\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
					"name": "Sans",
					"slug": "sans"
				},
				{
					"fontFace": [
						{
							"fontFamily": "Manrope",
							"fontStyle": "normal",
							"fontWeight": "400",
							"src": [
								"file:./assets/fonts/manrope/manrope-400-normal.woff2"
							]
						}
					],
					"fontFamily": "Manrope, sans-serif",
					"name": "Manrope",
					"slug": "manrope"
				}
			],
			"fontSizes": [
				{
					"name": "Small",
					"size": "0.875rem",
					"slug": "small"
				},
				{
					"name": "Medium",
					"size": "1rem",
					"slug": "medium"
				},
				{
					"name": "Large",
					"size": "32px",
					"slug": "large"
				},
				{
					"name": "Larger",
					"size": "clamp(1.25rem, 2.3vw, 2rem)",
					"slug": "larger"
				},
				{
					"name": "Section Title",
					"size": "clamp(2.5rem, 6vw, 5rem)",
					"slug": "section-title"
				},
				{
					"name": "Hero Intro",
					"size": "clamp(1.0625rem, 5vw, 1.1875rem)",
					"slug": "hero-intro"
				},
				{
					"name": "Hero",
					"size": "clamp(2.5rem, 8vw, 5rem)",
					"slug": "hero"
				}
			]
		}
	},
	"styles": {
		"blocks": {
			"core/button": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--mono)"
				}
			},
			"core/navigation": {
				"color": {
					"text": "var(--wp--preset--color--foreground)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--mono)",
					"fontSize": "var(--wp--preset--font-size--small)",
					"letterSpacing": "0.05em"
				}
			},
			"core/post-date": {
				"color": {
					"text": "var(--wp--preset--color--accent)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--mono)",
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/post-excerpt": {
				"color": {
					"text": "var(--wp--preset--color--muted)"
				}
			},
			"core/post-title": {
				"color": {
					"text": "var(--wp--preset--color--foreground)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--sans)",
					"fontWeight": "600",
					"lineHeight": "1.2"
				}
			}
		},
		"color": {
			"gradient": "var(--wp--preset--gradient--background-gradient)",
			"text": "var(--wp--preset--color--foreground)"
		},
		"elements": {
			"button": {
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--accent)",
						"text": "var(--wp--preset--color--foreground)"
					}
				},
				"border": {
					"color": "var(--wp--preset--color--accent)",
					"radius": "4px",
					"style": "solid",
					"width": "2px"
				},
				"color": {
					"background": "transparent",
					"text": "var(--wp--preset--color--accent)"
				},
				"spacing": {
					"padding": {
						"bottom": "1rem",
						"left": "2rem",
						"right": "2rem",
						"top": "1rem"
					}
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--mono)",
					"fontSize": "var(--wp--preset--font-size--small)",
					"letterSpacing": "0.05em"
				}
			},
			"h1": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--sans)",
					"fontWeight": "700",
					"lineHeight": "1.1"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--sans)",
					"fontWeight": "700",
					"lineHeight": "1.1"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--sans)",
					"fontWeight": "600",
					"lineHeight": "1.2"
				}
			},
			"link": {
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--foreground)"
					}
				},
				"color": {
					"text": "var(--wp--preset--color--accent)"
				}
			}
		},
		"spacing": {
			"blockGap": "1.5rem",
			"padding": {
				"left": "clamp(1.25rem, 5vw, 3rem)",
				"right": "clamp(1.25rem, 5vw, 3rem)"
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--sans)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.6"
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Header"
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Footer"
		}
	]
}
